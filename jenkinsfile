pipeline{
    agent any
    tools {
        jdk 'java-17'
        maven 'maven'
    }

    environment {
        IMAGE_NAME = "roopa3107/itkannada:${GIT_COMMIT}"
    }

    stages{
        stage('git-checkout'){
            steps{
                git url: 'https://github.com/roopadh7/ITKannadigaru-Java-based-app.git', branch: 'main'
            }
        }

        stage('mvn compile'){
            steps{
                sh '''
                    mvn compile
                '''
            }
        }

        stage('mvn package'){
            steps{
                sh'''
                    mvn clean package
                '''
            }
        }

        stage('Docker-build'){
            steps{
                sh'''
                    docker build -t ${IMAGE_NAME} .
                '''
            }
        }

        stage('test'){
            steps{
                sh'''
                    docker rm -f push1 || true
                    docker run -d --name push1 -p 8081:80 ${IMAGE_NAME}
                '''
            }
        }

        stage('login to docker'){
            steps{
                script {
                    withCredentials([usernamePassword(credentialsId: 'docker-hub-creds', 
                                         passwordVariable: 'DOCKER_PASSWORD', 
                                         usernameVariable: 'DOCKER_USERNAME')]) {
            // The "body" starts here
            sh "echo \$DOCKER_PASSWORD | docker login -u \$DOCKER_USERNAME --password-stdin"
        }
                }
            }
        }

        stage('docker push'){
            steps{
                sh'''
                    docker push ${IMAGE_NAME}
                '''
            }
        }


    }
}
