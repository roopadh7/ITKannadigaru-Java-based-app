pipeline{
    agent any
    tools {
        jdk 'java-17'
        maven 'maven'
    }

    environment {
        IMAGE_NAME = "roopa3107/ITKannad:${GIT_COMMIT}"
    }

    stages{
        stage('git-checkout'){
            steps{
                git url: 'https://github.com/roopadh7/ITKannadigaru-Java-based-app.git', branch: 'main'
            }
        }

        stage('mvn compile'){
            steps{
                sh '''
                    mvn compile
                '''
            }
        }

        stage('mvn package'){
            steps{
                sh'''
                    mvn clean package
                '''
            }
        }

        stage('Docker-build'){
            steps{
                sh'''
                    docker build -t ${IMAGE_NAME} .
                '''
            }
        }

        stage('test'){
            steps{
                sh'''
                    docker run -it -d --name Kannada -p 8080:8000 ${IMAGE_NAME}
                '''

            }
        }

        
    }
}
